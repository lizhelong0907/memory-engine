{
  "id": "memory-engine",
  "kind": "memory",
  "name": "memory-engine",
  "version": "2.0.0",
  "displayName": "Memory Engine V2",
  "description": "Context management plugin using Context Engine API",
  "author": "",
  "homepage": "",
  "repository": "",
  "license": "MIT",
  "engines": {
    "openclaw": ">=3.8.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "tools": [
    {
      "name": "memory_save",
      "description": "保存重要信息到记忆系统",
      "inputSchema": {
        "type": "object",
        "properties": {
          "content": { "type": "string", "description": "要记忆的内容" },
          "type": { "type": "string", "enum": ["fact", "experience", "lesson", "preference"], "description": "记忆类型" },
          "importance": { "type": "number", "minimum": 0, "maximum": 1, "description": "重要性 0-1" }
        },
        "required": ["content"]
      }
    },
    {
      "name": "memory_search",
      "description": "搜索记忆",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "搜索关键词" },
          "limit": { "type": "number", "default": 5 }
        },
        "required": ["query"]
      }
    },
    {
      "name": "memory_list",
      "description": "列出所有记忆",
      "inputSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["fact", "experience", "lesson", "preference"] },
          "limit": { "type": "number", "default": 20 }
        }
      }
    },
    {
      "name": "memory_stats",
      "description": "获取记忆统计"
    }
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "dbPath": {
        "type": "string",
        "default": "./data/memories.db",
        "description": "SQLite数据库路径"
      }
    }
  }
}
